---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin-bottom: 2.5rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.hero h1 {
				margin-bottom: 0.5rem;
				font-size: 2rem;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.05rem;
				margin: 0;
			}
			.posts-grid {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}
			.post-card a {
				display: grid;
				grid-template-columns: 200px 1fr;
				text-decoration: none;
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				background: white;
				box-shadow: 0 1px 4px rgba(var(--gray), 12%);
				transition: box-shadow 0.2s ease, transform 0.2s ease;
			}
			.post-card a:hover {
				box-shadow: 0 4px 16px rgba(var(--gray), 28%);
				transform: translateY(-2px);
			}
			.post-cover {
				width: 200px;
				height: 130px;
				overflow: hidden;
				flex-shrink: 0;
			}
			.post-cover img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				display: block;
			}
			.post-cover-placeholder {
				width: 200px;
				height: 130px;
				background: rgb(var(--gray-light));
				flex-shrink: 0;
			}
			.post-info {
				padding: 1rem 1.25rem;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0.35rem;
			}
			.post-title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.1rem;
				font-weight: 700;
				line-height: 1.3;
				transition: color 0.2s ease;
			}
			.post-card a:hover .post-title {
				color: var(--accent);
			}
			.post-description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.88rem;
				line-height: 1.5;
			}
			.post-date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.82rem;
			}
			@media (max-width: 600px) {
				.post-card a {
					grid-template-columns: 1fr;
				}
				.post-cover,
				.post-cover-placeholder {
					width: 100%;
					height: 180px;
				}
				.post-info {
					padding: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Промышленная автоматизация и энергетика</h1>
				<p>Для тех, кто выбирает оборудование на производстве — без рекламы, без теории ради теории.</p>
			</div>
			<ul class="posts-grid">
				{
					posts.map((post) => (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage ? (
									<div class="post-cover">
										<Image src={post.data.heroImage} alt={post.data.title} width={200} height={130} />
									</div>
								) : (
									<div class="post-cover-placeholder" />
								)}
								<div class="post-info">
									<h4 class="post-title">{post.data.title}</h4>
									<p class="post-description">{post.data.description}</p>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
