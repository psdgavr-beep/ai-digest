{
  "permissions": {
    "allow": [
      "npm run dev",
      "npm run build",
      "npm run preview",
      "git status",
      "git log",
      "git diff",
      "git add",
      "git commit"
    ],
    "deny": [
      "*.env*",
      "git push --force",
      "rm -rf",
      "git reset --hard"
    ]
  }
}
