{
  "permissions": {
    "allow": [
      "npm run dev",
      "npm run build",
      "npm run preview",
      "git status",
      "git log",
      "git diff",
      "git add",
      "git commit"
    ],
    "deny": [
      "*.env*",
      "git push --force",
      "rm -rf",
      "git reset --hard"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git log --oneline -10 > \"C:/Users/Пользователь/.claude/projects/C--Users--------------Desktop-----------------aiobuchblog/memory/last_git_log.txt\""
          }
        ]
      }
    ]
  }
}
